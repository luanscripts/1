-- ==================================================
-- ✅ ANIMAÇÃO ABRIR / FECHAR
-- ==================================================
local function Animar(abrir)
    if abrindo then return end
    abrindo = true
    if abrir then
        MenuFora.Visible=true
        MenuFora.Size=TAMANHO_FECHADO MenuFora.BackgroundTransparency=1
        MenuDentro.BackgroundTransparency=1 Titulo.BackgroundTransparency=1 LadoAbas.BackgroundTransparency=1
        A1.BackgroundTransparency=1 A2.BackgroundTransparency=1 A3.BackgroundTransparency=1
        local t1=TweenService:Create(MenuFora,ESTILO,{Size=TAMANHO_NORMAL,BackgroundTransparency=0})
        local t2=TweenService:Create(MenuDentro,ESTILO,{BackgroundTransparency=0})
        local t3=TweenService:Create(Titulo,ESTILO,{BackgroundTransparency=0})
        local t4=TweenService:Create(LadoAbas,ESTILO,{BackgroundTransparency=0})
        local t5=TweenService:Create(A1,ESTILO,{BackgroundTransparency=0})
        local t6=TweenService:Create(A2,ESTILO,{BackgroundTransparency=0})
        local t7=TweenService:Create(A3,ESTILO,{BackgroundTransparency=0})
        t1:Play()t2:Play()t3:Play()t4:Play()t5:Play()t6:Play()t7:Play()
        t1.Completed:Wait()
    else
        local t1=TweenService:Create(MenuFora,ESTILO,{Size=TAMANHO_FECHADO,BackgroundTransparency=1})
        local t2=TweenService:Create(MenuDentro,ESTILO,{BackgroundTransparency=1})
        local t3=TweenService:Create(Titulo,ESTILO,{BackgroundTransparency=1})
        local t4=TweenService:Create(LadoAbas,ESTILO,{BackgroundTransparency=1})
        t1:Play()t2:Play()t3:Play()t4:Play()
        t1.Completed:Wait()
        MenuFora.Visible=false
    end
    abrindo=false
end

