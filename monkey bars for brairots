local menuAberto=false
local function AbrirFechar()
    TocarSomPorta()
    menuAberto=not menuAberto
    Toggle.Text=menuAberto and "FECHAR" or "ABRIR"
    Animar(menuAberto)
end
Toggle.MouseButton1Click:Connect(AbrirFechar)
FecharX.MouseButton1Click:Connect(AbrirFechar)

local function MudarAba(x)
    TocarSomPorta()
    P1.Visible=false P2.Visible=false P3.Visible=false
    for _,a in pairs({A1,A2,A3}) do
        a.BackgroundColor3=Color3.fromRGB(25,25,25)
        a.TextColor3=Color3.new(0.7,0.7,0.7)
    end
    if x==1 then P1.Visible=true A1.BackgroundColor3=Color3.fromRGB(40,40,40) A1.TextColor3=Color3.new(1,1,1)
    elseif x==2 then P2.Visible=true A2.BackgroundColor3=Color3.fromRGB(40,40,40) A2.TextColor3=Color3.new(1,1,1)
    elseif x==3 then P3.Visible=true A3.BackgroundColor3=Color3.fromRGB(40,40,40) A3.TextColor3=Color3.new(1,1,1) end
end

A1.MouseButton1Click:Connect(function() MudarAba(1) end)
A2.MouseButton1Click:Connect(function() MudarAba(2) end)
A3.MouseButton1Click:Connect(function() MudarAba(3) end)

